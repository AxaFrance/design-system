{
  "name": "@axa-fr/design-system-slash-css",
  "version": "0.1.0",
  "description": "",
  "main": "index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "predev": "rimraf dist",
    "dev": "postcss \"src/**/*.scss\" --base src --dir dist --ext css --verbose --watch --config postcss.dev.config.js",
    "prebuild": "rimraf dist",
    "build": "postcss \"src/**/*.scss\" --base src --dir dist --ext css --verbose --config postcss.prod.config.js && npm run copy:scss && npm run copy:assets",
    "copy:scss": "copyfiles --up 1 src/**/*.scss dist/",
    "copy:assets": "copyfiles --up 2 ../../common/**/* dist/",
    "stylelint": "stylelint \"src/**/*.{scss,css}\"",
    "stylelint:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
    "prettier": "prettier \"src/**/*\" --check",
    "prettier:fix": "prettier \"src/**/*\" --write"
  },
  "devDependencies": {
    "@axa-fr/eslint-config-design-system": "*",
    "@axa-fr/postcss-config-design-system": "*",
    "@axa-fr/prettier-config-design-system": "*",
    "@axa-fr/stylelint-config-design-system": "*",
    "copyfiles": "^2.4.1"
  },
  "peerDependencies": {
    "@material-symbols/svg-400": ">= 0.19.0"
  },
  "peerDependenciesMeta": {
    "@material-symbols/svg-400": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AxaFrance/design-system.git"
  },
  "author": {
    "name": "AxaFrance"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AxaFrance/design-system/issues"
  },
  "homepage": "https://github.com/AxaFrance/design-system#readme",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.(js|jsx|ts|tsx)": "eslint --fix",
    "*.(ts|tsx)": "tsc-files --noEmit",
    "*.(scss|css)": "stylelint --fix",
    "*.mdx": "prettier --write"
  },
  "prettier": "@axa-fr/prettier-config-design-system",
  "volta": {
    "extends": "../../package.json"
  }
}